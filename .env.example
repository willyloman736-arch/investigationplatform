# ──────────────────────────────────────────────────────────────
# AEGIS — Secure Escrow & Investigation Management
# Copy this file to `.env.local` and fill in the values.
# NEVER commit real secrets. .env.local is gitignored.
# ──────────────────────────────────────────────────────────────

# Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — bypasses Row Level Security. Never expose to the browser
# or import into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# Licensed escrow / payment provider (placeholder abstraction) ─
# These power lib/escrow/provider.ts and the protected server routes.
# Real fund movement must be wired to a LICENSED provider here.
ESCROW_PROVIDER_API_KEY=
ESCROW_PROVIDER_WEBHOOK_SECRET=

# App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode: when "true", the auth guard is bypassed and the UI renders
# from mock data so the app is viewable without Supabase configured.
# MUST be "false" (or unset) in production.
NEXT_PUBLIC_DEMO_MODE=true
