# ──────────────────────────────────────────────────────────────
# Digital Asset Investigations — Secure Escrow & Investigation Management
# Copy this file to `.env.local` and fill in the values.
# NEVER commit real secrets. .env.local is gitignored.
# ──────────────────────────────────────────────────────────────

# Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — bypasses Row Level Security. Never expose to the browser
# or import into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# Licensed escrow / payment provider (placeholder abstraction) ─
# These power lib/escrow/provider.ts and the protected server routes.
# Real fund movement must be wired to a LICENSED provider here.
ESCROW_PROVIDER_API_KEY=
ESCROW_PROVIDER_WEBHOOK_SECRET=

# App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode: when "true", the auth guard is bypassed and the UI renders
# from mock data so the app is viewable without Supabase configured.
# MUST be "false" (or unset) in production.
NEXT_PUBLIC_DEMO_MODE=true

# Notifications — email (Resend) ──────────────────────────────
# Get an API key at https://resend.com. EMAIL_FROM must be a verified sender /
# domain (falls back to Resend's onboarding sender for testing). Optional:
# without RESEND_API_KEY, email notifications are skipped (in-app + push still work).
RESEND_API_KEY=
EMAIL_FROM="Digital Asset Investigations <notifications@yourdomain.com>"

# Notifications — Web Push (VAPID) ────────────────────────────
# Generate once with:  npm run generate:vapid   (or: npx web-push generate-vapid-keys)
# The PUBLIC key must be set BOTH server-side (VAPID_PUBLIC_KEY) and exposed to
# the browser (NEXT_PUBLIC_VAPID_PUBLIC_KEY). Without these, push is skipped.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:notifications@yourdomain.com
